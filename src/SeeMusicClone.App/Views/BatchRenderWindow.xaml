<Window x:Class="SeeMusicClone.App.Views.BatchRenderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Batch Render MIDI Files to Video" Height="420" Width="560"
        WindowStartupLocation="CenterOwner" Background="#0F0F14">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="Input folder (MIDI files):" Foreground="White" Width="170" VerticalAlignment="Center"/>
            <TextBox x:Name="InputFolderBox" Width="260" Margin="0,0,8,0"/>
            <Button Content="Browse..." Click="BrowseInput_Click"/>
        </StackPanel>

        <StackPanel Orientation="Horizontal" Grid.Row="1" Margin="0,0,0,10">
            <TextBlock Text="Output folder (videos):" Foreground="White" Width="170" VerticalAlignment="Center"/>
            <TextBox x:Name="OutputFolderBox" Width="260" Margin="0,0,8,0"/>
            <Button Content="Browse..." Click="BrowseOutput_Click"/>
        </StackPanel>

        <StackPanel Orientation="Horizontal" Grid.Row="2" Margin="0,0,0,10">
            <TextBlock Text="Resolution:" Foreground="White" Width="170" VerticalAlignment="Center"/>
            <ComboBox x:Name="ResolutionCombo" Width="200" SelectedIndex="0">
                <ComboBoxItem Content="1920x1080"/>
                <ComboBoxItem Content="1280x720"/>
                <ComboBoxItem Content="3840x2160"/>
            </ComboBox>
        </StackPanel>

        <StackPanel Orientation="Horizontal" Grid.Row="3" Margin="0,0,0,10">
            <TextBlock Text="Note speed (px/s):" Foreground="White" Width="170" VerticalAlignment="Center"/>
            <Slider x:Name="SpeedSlider" Minimum="80" Maximum="600" Value="140" Width="200"/>
            <TextBlock Text="{Binding ElementName=SpeedSlider, Path=Value, StringFormat={}{0:0}}"
                       Foreground="White" Width="40" VerticalAlignment="Center"/>
        </StackPanel>

        <StackPanel Orientation="Horizontal" Grid.Row="4" Margin="0,0,0,10">
            <TextBlock Text="FPS:" Foreground="White" Width="170" VerticalAlignment="Center"/>
            <ComboBox x:Name="FpsCombo" Width="100" SelectedIndex="0">
                <ComboBoxItem Content="30"/>
                <ComboBoxItem Content="60"/>
            </ComboBox>
        </StackPanel>

        <ListBox x:Name="LogList" Grid.Row="5" Background="#1A1A22" Foreground="#CCCCCC" Margin="0,0,0,10"/>

        <StackPanel Orientation="Horizontal" Grid.Row="6" HorizontalAlignment="Right">
            <ProgressBar x:Name="Progress" Width="220" Height="20" Margin="0,0,10,0"/>
            <Button x:Name="RenderButton" Content="Render All" Padding="14,5" Click="RenderButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
