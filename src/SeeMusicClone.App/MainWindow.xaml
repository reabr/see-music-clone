<Window x:Class="SeeMusicClone.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:SeeMusicClone.App.Controls"
        Title="See Music Clone - Falling Notes Piano Visualizer"
        Height="820"
        Width="1320"
        MinHeight="650"
        MinWidth="980"
        Background="#0D0D0F"
        FontFamily="Segoe UI">

    <Window.Resources>
        <SolidColorBrush x:Key="WindowBrush" Color="#0D0D0F"/>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#171618"/>
        <SolidColorBrush x:Key="SurfaceAltBrush" Color="#1D1B1E"/>
        <SolidColorBrush x:Key="ControlBrush" Color="#242226"/>
        <SolidColorBrush x:Key="ControlHoverBrush" Color="#302D33"/>
        <SolidColorBrush x:Key="BorderBrush2" Color="#3A363C"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#4FC3F7"/>
        <SolidColorBrush x:Key="TextBrush" Color="#EEF4FA"/>
        <SolidColorBrush x:Key="MutedTextBrush" Color="#AAA3AD"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>

        <Style x:Key="MutedText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource ControlBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush2}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource ControlHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.82"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.42"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="#071018"/>
            <Setter Property="MinWidth" Value="86"/>
        </Style>

        <Style x:Key="QuietButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#1E1B20"/>
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}"/>
        </Style>

        <Style TargetType="Slider">
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="MinHeight" Value="24"/>
        </Style>

        <Style x:Key="ValueBadge" TargetType="Border">
            <Setter Property="Background" Value="#101012"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush2}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="MinWidth" Value="64"/>
        </Style>
    </Window.Resources>

    <DockPanel LastChildFill="True" Background="{StaticResource WindowBrush}">

        <Border DockPanel.Dock="Top"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush2}"
                BorderThickness="0,0,0,1">
            <Grid Margin="18,14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="10"
                            Height="28"
                            CornerRadius="5"
                            Background="{StaticResource AccentBrush}"
                            Margin="0,0,10,0"/>
                    <StackPanel>
                        <TextBlock Text="See Music Clone"
                                   FontSize="18"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding Song.FileName, FallbackValue=No MIDI loaded, TargetNullValue=No MIDI loaded}"
                                   Style="{StaticResource MutedText}"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Row="0"
                            Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <Button Content="Open MIDI"
                            Command="{Binding OpenFileCommand}"
                            Margin="0,0,8,0"/>
                    <Button Content="Batch Render"
                            Command="{Binding OpenBatchRenderCommand}"
                            Style="{StaticResource QuietButton}"/>
                </StackPanel>

                <WrapPanel Grid.Row="1"
                           Grid.ColumnSpan="2"
                           Margin="0,16,0,0"
                           VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Margin="0,0,18,8">
                        <Button Content="{Binding PlayPauseText}"
                                Command="{Binding PlayPauseCommand}"
                                Style="{StaticResource PrimaryButton}"
                                Margin="0,0,8,0"/>
                        <Button Content="Stop"
                                Command="{Binding StopCommand}"
                                Style="{StaticResource QuietButton}"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,18,8" VerticalAlignment="Center">
                        <TextBlock Text="Note Speed"
                                   Style="{StaticResource SectionLabel}"
                                   Width="76"/>
                        <Slider x:Name="NoteSpeedSlider"
                                Minimum="80"
                                Maximum="600"
                                Width="160"
                                Value="{Binding NoteSpeed}"
                                Margin="0,0,8,0"/>
                        <Border Style="{StaticResource ValueBadge}">
                            <TextBlock Text="{Binding NoteSpeed, StringFormat={}{0:0} px/s}"
                                       HorizontalAlignment="Center"
                                       FontFamily="Consolas"/>
                        </Border>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,18,8" VerticalAlignment="Center">
                        <TextBlock Text="Playback"
                                   Style="{StaticResource SectionLabel}"
                                   Width="62"/>
                        <Slider Minimum="0.25"
                                Maximum="2.0"
                                Width="135"
                                Value="{Binding PlaybackSpeed}"
                                Margin="0,0,8,0"/>
                        <Border Style="{StaticResource ValueBadge}">
                            <TextBlock Text="{Binding PlaybackSpeed, StringFormat={}{0:0.00}x}"
                                       HorizontalAlignment="Center"
                                       FontFamily="Consolas"/>
                        </Border>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8" VerticalAlignment="Center">
                        <TextBlock Text="Audio Sync"
                                   Style="{StaticResource SectionLabel}"
                                   Width="70"/>
                        <Slider Minimum="-1.0"
                                Maximum="1.0"
                                Width="150"
                                Value="{Binding AudioOffsetSeconds}"
                                Margin="0,0,8,0"
                                ToolTip="Negative delays the visuals; positive advances the visuals."/>
                        <Border Style="{StaticResource ValueBadge}">
                            <TextBlock Text="{Binding AudioOffsetSeconds, StringFormat={}{0:0.00}s}"
                                       HorizontalAlignment="Center"
                                       FontFamily="Consolas"/>
                        </Border>
                    </StackPanel>
                </WrapPanel>
            </Grid>
        </Border>

        <Border DockPanel.Dock="Bottom"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush2}"
                BorderThickness="0,1,0,0">
            <Grid Margin="18,12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Row="0"
                        Grid.Column="0"
                        Style="{StaticResource ValueBadge}"
                        Margin="0,0,10,0">
                    <TextBlock Text="{Binding CurrentTimeDisplay}"
                               FontFamily="Consolas"
                               HorizontalAlignment="Center"/>
                </Border>

                <Slider Grid.Row="0"
                        Grid.Column="1"
                        x:Name="SeekSlider"
                        Minimum="0"
                        Maximum="{Binding Song.DurationSeconds}"
                        Value="{Binding CurrentTime, Mode=OneWay}"
                        IsMoveToPointEnabled="True"
                        VerticalAlignment="Center"/>

                <Border Grid.Row="0"
                        Grid.Column="2"
                        Style="{StaticResource ValueBadge}"
                        Margin="10,0,0,0">
                    <TextBlock Text="{Binding DurationDisplay}"
                               FontFamily="Consolas"
                               HorizontalAlignment="Center"/>
                </Border>

                <TextBlock Grid.Row="1"
                           Grid.ColumnSpan="3"
                           Text="{Binding StatusText}"
                           Style="{StaticResource MutedText}"
                           Margin="0,8,0,0"/>
            </Grid>
        </Border>

        <Grid Margin="18,14,18,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="150"/>
            </Grid.RowDefinitions>

            <Border Grid.RowSpan="2"
                    Background="{StaticResource SurfaceAltBrush}"
                    BorderBrush="{StaticResource BorderBrush2}"
                    BorderThickness="1"
                    CornerRadius="8"/>

            <controls:FallingNotesControl x:Name="FallingNotes"
                                          Grid.Row="0"
                                          Margin="1,1,1,0"
                                          Notes="{Binding Notes}"
                                          CurrentTime="{Binding VisualTime}"
                                          NoteSpeed="{Binding NoteSpeed}"/>

            <Border Grid.Row="1"
                    Margin="1,0,1,1"
                    Background="#08080A">
                <controls:PianoKeyboardControl x:Name="Keyboard"/>
            </Border>
        </Grid>
    </DockPanel>
</Window>
