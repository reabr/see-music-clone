<Window x:Class="SeeMusicClone.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:SeeMusicClone.App.Controls"
        Title="See Music Clone — Falling Notes Piano Visualizer" Height="800" Width="1300"
        Background="#0F0F14">
    <DockPanel LastChildFill="True">

        <Grid DockPanel.Dock="Top" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal">
                <Button Content="Open MIDI..." Command="{Binding OpenFileCommand}" Padding="10,5" Margin="0,0,8,0"/>
                <Button Content="{Binding PlayPauseText}" Command="{Binding PlayPauseCommand}" Padding="10,5" Margin="0,0,8,0" Width="70"/>
                <Button Content="Stop" Command="{Binding StopCommand}" Padding="10,5" Margin="0,0,20,0"/>
            </StackPanel>

            <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="Note Speed:" Foreground="White" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <Slider Minimum="80" Maximum="800" Width="180"
                        Value="{Binding NoteSpeed, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="{Binding NoteSpeed, StringFormat={}{0:0} px/s}" Foreground="White"
                           VerticalAlignment="Center" Width="76" Margin="0,0,20,0"/>

                <TextBlock Text="Playback:" Foreground="White" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <Slider Minimum="0.25" Maximum="2.0" Width="140"
                        Value="{Binding PlaybackSpeed, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="{Binding PlaybackSpeed, StringFormat={}{0:0.00}x}" Foreground="White"
                           VerticalAlignment="Center" Width="50"/>
            </StackPanel>

            <Button Grid.Row="0" Grid.Column="2" Content="Batch Render..." Command="{Binding OpenBatchRenderCommand}"
                    Padding="10,5"/>

            <Grid Grid.Row="1" Grid.ColumnSpan="3" Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="52"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="64"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="{Binding CurrentTime, StringFormat={}{0:0.0}s}" Foreground="#CCCCCC"
                           VerticalAlignment="Center"/>
                <Slider Grid.Column="1" Minimum="0" Maximum="{Binding DurationSeconds}"
                        Value="{Binding CurrentTime, UpdateSourceTrigger=PropertyChanged}"
                        IsEnabled="{Binding HasSong}" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2" Text="{Binding DurationSeconds, StringFormat={}{0:0.0}s}" Foreground="#CCCCCC"
                           TextAlignment="Right" VerticalAlignment="Center"/>
            </Grid>
        </Grid>

        <!-- Status bar -->
        <TextBlock DockPanel.Dock="Bottom" Text="{Binding StatusText}" Foreground="#AAAAAA"
                   Margin="10,0,10,10"/>

        <!-- Falling notes above, keyboard below -->
        <Grid Margin="10,0,10,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="150"/>
            </Grid.RowDefinitions>

            <controls:FallingNotesControl x:Name="FallingNotes" Grid.Row="0"
                Notes="{Binding Notes}"
                CurrentTime="{Binding CurrentTime}"
                NoteSpeed="{Binding NoteSpeed}"/>

            <controls:PianoKeyboardControl x:Name="Keyboard" Grid.Row="1"/>
        </Grid>
    </DockPanel>
</Window>
