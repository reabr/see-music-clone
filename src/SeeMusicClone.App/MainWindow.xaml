<Window x:Class="SeeMusicClone.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:SeeMusicClone.App.Controls"
        Title="See Music Clone — Falling Notes Piano Visualizer" Height="800" Width="1300"
        Background="#0F0F14">
    <DockPanel LastChildFill="True">

        <!-- Top toolbar -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="10" >
            <Button Content="Open MIDI..." Command="{Binding OpenFileCommand}" Padding="10,5" Margin="0,0,8,0"/>
            <Button Content="{Binding IsPlaying, Converter={x:Null}, FallbackValue=Play}"
                    Command="{Binding PlayPauseCommand}" Padding="10,5" Margin="0,0,8,0" Width="70"/>
            <Button Content="Stop" Command="{Binding StopCommand}" Padding="10,5" Margin="0,0,20,0"/>

            <TextBlock Text="Note Speed:" Foreground="White" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <Slider x:Name="NoteSpeedSlider" Minimum="80" Maximum="600" Width="180"
                    Value="{Binding NoteSpeed}" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBlock Text="{Binding NoteSpeed, StringFormat={}{0:0} px/s}" Foreground="White"
                       VerticalAlignment="Center" Width="70" Margin="0,0,20,0"/>

            <TextBlock Text="Playback Speed:" Foreground="White" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <Slider Minimum="0.25" Maximum="2.0" Width="140" Value="{Binding PlaybackSpeed}"
                    VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBlock Text="{Binding PlaybackSpeed, StringFormat={}{0:0.00}x}" Foreground="White"
                       VerticalAlignment="Center" Width="50" Margin="0,0,20,0"/>

            <Button Content="Batch Render..." Command="{Binding OpenBatchRenderCommand}" Padding="10,5"/>
        </StackPanel>

        <!-- Status bar -->
        <TextBlock DockPanel.Dock="Bottom" Text="{Binding StatusText}" Foreground="#AAAAAA"
                   Margin="10,0,10,10"/>

        <!-- Falling notes above, keyboard below -->
        <Grid Margin="10,0,10,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="150"/>
            </Grid.RowDefinitions>

            <controls:FallingNotesControl x:Name="FallingNotes" Grid.Row="0"
                Notes="{Binding Notes}"
                CurrentTime="{Binding CurrentTime}"
                NoteSpeed="{Binding NoteSpeed}"/>

            <controls:PianoKeyboardControl x:Name="Keyboard" Grid.Row="1"/>
        </Grid>
    </DockPanel>
</Window>
