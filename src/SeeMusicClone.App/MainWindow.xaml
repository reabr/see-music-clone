<Window x:Class="SeeMusicClone.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:SeeMusicClone.App.Controls"
        Title="See Music Clone — Falling Notes Piano Visualizer"
        Height="800"
        Width="1300"
        Background="#0F0F14">

    <Window.Resources>
        <SolidColorBrush x:Key="AccentBrush"
                Color="#4FC3F7"/>
        <SolidColorBrush x:Key="PanelBrush"
                Color="#1A1A22"/>
        <SolidColorBrush x:Key="BorderBrush2"
                Color="#2A2A34"/>

        <Style TargetType="Button">
            <Setter Property="Background"
                    Value="#22222C"/>
            <Setter Property="Foreground"
                    Value="White"/>
            <Setter Property="BorderBrush"
                    Value="{StaticResource BorderBrush2}"/>
            <Setter Property="Padding"
                    Value="12,6"/>
            <Setter Property="Cursor"
                    Value="Hand"/>
            <Setter Property="FontSize"
                    Value="13"/>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground"
                    Value="#DDDDDD"/>
            <Setter Property="FontSize"
                    Value="12"/>
        </Style>

        <Style TargetType="Slider">
            <Setter Property="Foreground"
                    Value="{StaticResource AccentBrush}"/>
        </Style>
    </Window.Resources>

    <DockPanel LastChildFill="True">

        <!-- Top toolbar -->
        <Border DockPanel.Dock="Top"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush2}"
                BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal"
                    Margin="12,10">
                <Button Content="Open MIDI..."
                        Command="{Binding OpenFileCommand}"
                        Margin="0,0,8,0"/>
                <Button Content="{Binding IsPlaying, Converter={x:Null}, FallbackValue=Play}"
                        Command="{Binding PlayPauseCommand}"
                        Margin="0,0,4,0"
                        Width="70"
                        Background="{StaticResource AccentBrush}"
                        Foreground="#0F0F14"
                        FontWeight="SemiBold"/>
                <Button Content="Stop"
                        Command="{Binding StopCommand}"
                        Margin="0,0,24,0"/>

                <TextBlock Text="Note Speed"
                        VerticalAlignment="Center"
                        Margin="0,0,8,0"/>
                <Slider x:Name="NoteSpeedSlider"
                        Minimum="80"
                        Maximum="600"
                        Width="150"
                        Value="{Binding NoteSpeed}"
                        VerticalAlignment="Center"
                        Margin="0,0,6,0"/>
                <TextBlock Text="{Binding NoteSpeed, StringFormat={}{0:0} px/s}"
                           VerticalAlignment="Center"
                        Width="65"
                        Margin="0,0,20,0"/>

                <TextBlock Text="Playback Speed"
                        VerticalAlignment="Center"
                        Margin="0,0,8,0"/>
                <Slider Minimum="0.25"
                        Maximum="2.0"
                        Width="120"
                        Value="{Binding PlaybackSpeed}"
                        VerticalAlignment="Center"
                        Margin="0,0,6,0"/>
                <TextBlock Text="{Binding PlaybackSpeed, StringFormat={}{0:0.00}x}"
                           VerticalAlignment="Center"
                        Width="45"
                        Margin="0,0,20,0"/>

                <TextBlock Text="Audio Sync"
                        VerticalAlignment="Center"
                        Margin="0,0,8,0"
                           ToolTip="Adjust until notes hit the keyboard exactly when you hear them"/>
                <Slider Minimum="-0.3"
                        Maximum="0.3"
                        Width="100"
                        Value="{Binding AudioOffsetSeconds}"
                        VerticalAlignment="Center"
                        Margin="0,0,6,0"
                        ToolTip="Adjust until notes hit the keyboard exactly when you hear them"/>
                <TextBlock Text="{Binding AudioOffsetSeconds, StringFormat={}{0:0.00}s}"
                           VerticalAlignment="Center"
                        Width="50"
                        Margin="0,0,20,0"/>

                <Button Content="Batch Render..."
                        Command="{Binding OpenBatchRenderCommand}"/>
            </StackPanel>
        </Border>

        <!-- Status / seek bar -->
        <Border DockPanel.Dock="Bottom"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush2}"
                BorderThickness="0,1,0,0">
            <StackPanel Margin="12,8">
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                            Text="{Binding CurrentTime, StringFormat=mm\\:ss}"
                               VerticalAlignment="Center"
                            Margin="0,0,10,0"
                            FontFamily="Consolas"/>

                    <Slider Grid.Column="1"
                            x:Name="SeekSlider"
                            Minimum="0"
                            Maximum="{Binding Song.DurationSeconds}"
                            Value="{Binding CurrentTime, Mode=OneWay}"
                            IsMoveToPointEnabled="True"
                            VerticalAlignment="Center"/>

                    <TextBlock Grid.Column="2"
                            Text="{Binding Song.DurationSeconds, StringFormat=mm\\:ss}"
                               VerticalAlignment="Center"
                            Margin="10,0,0,0"
                            FontFamily="Consolas"/>
                </Grid>

                <TextBlock Text="{Binding StatusText}"
                        Foreground="#888888"
                        FontSize="11"/>
            </StackPanel>
        </Border>

        <!-- Falling notes above, keyboard below -->
        <Grid Margin="12,8,12,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="150"/>
            </Grid.RowDefinitions>

            <controls:FallingNotesControl x:Name="FallingNotes"
                    Grid.Row="0"
                                          Notes="{Binding Notes}"
                                          CurrentTime="{Binding CurrentTime}"
                                          NoteSpeed="{Binding NoteSpeed}"/>

            <controls:PianoKeyboardControl x:Name="Keyboard"
                    Grid.Row="1"/>
        </Grid>
    </DockPanel>
</Window>